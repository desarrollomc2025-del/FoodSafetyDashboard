@inherits LayoutComponentBase

<RadzenLayout style="height:100vh">
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" Style="width:100%">
            <RadzenSidebarToggle Click="@(() => _sidebarExpanded = !_sidebarExpanded)" />
            <RadzenText TextStyle="TextStyle.H6" Style="margin:0;color:#fff;font-weight:600;margin-left:8px">
                Food Safety Dashboard
            </RadzenText>
            <RadzenStack Style="margin-left:auto;margin-right:1rem">
                <RadzenText TextStyle="TextStyle.Body2" Style="color:rgba(255,255,255,0.8)">
                    FSE Internacional
                </RadzenText>
            </RadzenStack>
        </RadzenStack>
    </RadzenHeader>
    <RadzenSidebar @bind-Expanded="@_sidebarExpanded">
        <NavMenu />
    </RadzenSidebar>
    <RadzenBody>
        <div style="padding:1.5rem">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

@code {
    private bool _sidebarExpanded = true;
}
