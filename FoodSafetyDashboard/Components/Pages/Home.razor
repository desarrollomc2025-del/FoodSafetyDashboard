@page "/"
@rendermode InteractiveServer
@inject AuditService AuditSvc
@inject ExportService ExportSvc
@inject IJSRuntime JS
@using ApexCharts

<PageTitle>Resumen Ejecutivo</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Resumen Ejecutivo</RadzenText>

<RadzenCard class="rz-mb-4">
    <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px" Wrap="FlexWrap.Wrap">
        <RadzenDropDown @bind-Value="_year" Data="@_years"
                        AllowClear="true" Placeholder="Año" Style="width:130px"
                        Change="OnYearChanged" />
        <RadzenDropDown @bind-Value="_month" Data="@_monthOptions"
                        TextProperty="Text" ValueProperty="Value"
                        AllowClear="true" Placeholder="Mes" Style="width:150px" />
        <RadzenButton Text="Aplicar" ButtonStyle="ButtonStyle.Primary" Click="LoadData" />
        <RadzenButton Text="Excel" ButtonStyle="ButtonStyle.Success" Icon="download" Click="ExportExcel" />
    </RadzenStack>
</RadzenCard>

@if (_errorMsg is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mb-4">@_errorMsg</RadzenAlert>
}

@if (_loading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" class="rz-mb-4" />
}
else if (_kpis is not null)
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="6" SizeSM="4" SizeMD="2">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenIcon Icon="store" style="font-size:2rem;color:var(--rz-primary)" />
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-primary);font-weight:700">@_kpis.TotalStores</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">Tiendas Evaluadas</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeSM="4" SizeMD="2">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenIcon Icon="star" style="font-size:2rem;color:var(--rz-warning)" />
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-warning);font-weight:700">@_kpis.GlobalScore.ToString("F1")%</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">Nota Global</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeSM="4" SizeMD="2">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenIcon Icon="check_circle" style="font-size:2rem;color:var(--rz-success)" />
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-success);font-weight:700">@_kpis.Approved</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">Aprobadas</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeSM="4" SizeMD="2">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenIcon Icon="cancel" style="font-size:2rem;color:var(--rz-danger)" />
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-danger);font-weight:700">@_kpis.NotApproved</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">No Aprobadas</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeSM="4" SizeMD="2">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenIcon Icon="warning" style="font-size:2rem;color:var(--rz-danger)" />
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-danger);font-weight:700">@_kpis.CriticalStores</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">Con Críticos</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeSM="4" SizeMD="2">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenIcon Icon="trending_up" style="font-size:2rem;color:var(--rz-info)" />
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-info);font-weight:700">
                    @(_kpis.TotalStores > 0 ? (_kpis.Approved * 100.0 / _kpis.TotalStores).ToString("F0") : "0")%
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">% Aprobación</RadzenText>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard style="padding:1rem">
                <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3"><b>Nota Global por Grupo</b></RadzenText>
                <ApexChart TItem="GroupSummary" Options="_groupChartOptions" Height="280">
                    <ApexPointSeries TItem="GroupSummary"
                                     Items="_groups"
                                     SeriesType="SeriesType.Bar"
                                     Name="Nota %"
                                     XValue="@(g => g.Group)"
                                     YValue="@(g => (decimal)Math.Round(g.AvgScore, 1))"
                                     Color="#2E75B6" />
                </ApexChart>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard style="padding:1rem">
                <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3"><b>Promedio por Sección</b></RadzenText>
                <ApexChart TItem="SectionPoint" Options="_sectionChartOptions" Height="280">
                    <ApexPointSeries TItem="SectionPoint"
                                     Items="_sectionPoints"
                                     SeriesType="SeriesType.Bar"
                                     Name="Score %"
                                     XValue="@(s => s.Section)"
                                     YValue="@(s => (decimal)Math.Round(s.Score, 1))"
                                     Color="#70AD47" />
                </ApexChart>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard style="padding:1rem" class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3"><b>Nota por Sección — CLÁSICA vs DEX</b></RadzenText>
        <ApexChart TItem="SectionGroupPoint" Options="_sectionGroupOptions" Height="320">
            <ApexPointSeries TItem="SectionGroupPoint"
                             Items="@(_sectionGroupPoints.Where(p => p.Group == "CLÁSICA").ToList())"
                             SeriesType="SeriesType.Bar"
                             Name="CLÁSICA"
                             XValue="@(p => p.Section)"
                             YValue="@(p => (decimal)Math.Round(p.Score, 1))"
                             Color="#2E75B6" />
            <ApexPointSeries TItem="SectionGroupPoint"
                             Items="@(_sectionGroupPoints.Where(p => p.Group == "DEX").ToList())"
                             SeriesType="SeriesType.Bar"
                             Name="DEX"
                             XValue="@(p => p.Section)"
                             YValue="@(p => (decimal)Math.Round(p.Score, 1))"
                             Color="#ED7D31" />
        </ApexChart>
    </RadzenCard>

    <RadzenCard style="padding:1rem" class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3"><b>Nota por Tienda (mayor a menor)</b></RadzenText>
        <ApexChart TItem="StoreRow" Options="_storeRankOptions" Height="@(_rows.Count * 26 + 60)">
            <ApexPointSeries TItem="StoreRow"
                             Items="@(_rows.Where(r => r.Group == "CLÁSICA").ToList())"
                             SeriesType="SeriesType.Bar"
                             Name="CLÁSICA"
                             XValue="@(r => r.StoreId.ToString())"
                             YValue="@(r => (decimal)Math.Round(r.Score, 1))"
                             Color="#2E75B6" />
            <ApexPointSeries TItem="StoreRow"
                             Items="@(_rows.Where(r => r.Group == "DEX").ToList())"
                             SeriesType="SeriesType.Bar"
                             Name="DEX"
                             XValue="@(r => r.StoreId.ToString())"
                             YValue="@(r => (decimal)Math.Round(r.Score, 1))"
                             Color="#ED7D31" />
        </ApexChart>
    </RadzenCard>

    <RadzenCard style="padding:1rem" class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3"><b>Resultados por Grupo</b></RadzenText>
        <RadzenDataGrid Data="@_groups" TItem="GroupSummary" Density="Density.Compact" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="GroupSummary" Property="Group" Title="Grupo" Width="100px">
                    <Template Context="g"><b>@g.Group</b></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GroupSummary" Property="Count" Title="Tiendas" Width="80px" />
                <RadzenDataGridColumn TItem="GroupSummary" Property="AvgScore" Title="Nota %" Width="100px">
                    <Template Context="g">
                        <RadzenBadge Text="@($"{g.AvgScore:F1}%")" BadgeStyle="@ScoreBadgeStyle(g.AvgScore)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GroupSummary" Title="Fact. Riesgo" Width="110px">
                    <Template Context="g">@g.SectionAverages.GetValueOrDefault("Fact. Riesgo").ToString("F1")%</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GroupSummary" Title="Limpieza" Width="95px">
                    <Template Context="g">@g.SectionAverages.GetValueOrDefault("Limpieza").ToString("F1")%</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GroupSummary" Title="Mantenimiento" Width="120px">
                    <Template Context="g">@g.SectionAverages.GetValueOrDefault("Mantenimiento").ToString("F1")%</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GroupSummary" Title="Almacenaje" Width="100px">
                    <Template Context="g">@g.SectionAverages.GetValueOrDefault("Almacenaje").ToString("F1")%</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GroupSummary" Title="Conocimiento" Width="110px">
                    <Template Context="g">@g.SectionAverages.GetValueOrDefault("Conocimiento").ToString("F1")%</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GroupSummary" Property="Approved" Title="Aprobadas" Width="95px">
                    <Template Context="g"><span style="color:var(--rz-success)">@g.Approved</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="GroupSummary" Property="NotApproved" Title="No Aprobadas" Width="115px">
                    <Template Context="g"><span style="color:var(--rz-danger)">@g.NotApproved</span></Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>

    @if (_departamentos.Count > 0 || _municipios.Count > 0)
    {
        <RadzenRow Gap="1rem" class="rz-mb-4">
            @if (_departamentos.Count > 0)
            {
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenCard style="padding:1rem">
                        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3"><b>Tiendas Evaluadas por Departamento</b></RadzenText>
                        <RadzenDataGrid Data="@_departamentos" TItem="LocationSummary" Density="Density.Compact">
                            <Columns>
                                <RadzenDataGridColumn TItem="LocationSummary" Property="Name" Title="Departamento">
                                    <Template Context="d"><b>@d.Name</b></Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="LocationSummary" Property="Count" Title="Tiendas" Width="80px" />
                                <RadzenDataGridColumn TItem="LocationSummary" Property="AvgScore" Title="Nota %" Width="100px">
                                    <Template Context="d">
                                        <RadzenBadge Text="@($"{d.AvgScore:F1}%")" BadgeStyle="@ScoreBadgeStyle(d.AvgScore)" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="LocationSummary" Property="Approved" Title="Aprobadas" Width="95px">
                                    <Template Context="d"><span style="color:var(--rz-success)">@d.Approved</span></Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="LocationSummary" Property="NotApproved" Title="No Aprobadas" Width="115px">
                                    <Template Context="d"><span style="color:var(--rz-danger)">@d.NotApproved</span></Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenCard>
                </RadzenColumn>
            }
            @if (_municipios.Count > 0)
            {
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenCard style="padding:1rem">
                        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3"><b>Tiendas Evaluadas por Municipio</b></RadzenText>
                        <RadzenDataGrid Data="@_municipios" TItem="LocationSummary" Density="Density.Compact">
                            <Columns>
                                <RadzenDataGridColumn TItem="LocationSummary" Property="Name" Title="Municipio">
                                    <Template Context="m"><b>@m.Name</b></Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="LocationSummary" Property="Count" Title="Tiendas" Width="80px" />
                                <RadzenDataGridColumn TItem="LocationSummary" Property="AvgScore" Title="Nota %" Width="100px">
                                    <Template Context="m">
                                        <RadzenBadge Text="@($"{m.AvgScore:F1}%")" BadgeStyle="@ScoreBadgeStyle(m.AvgScore)" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="LocationSummary" Property="Approved" Title="Aprobadas" Width="95px">
                                    <Template Context="m"><span style="color:var(--rz-success)">@m.Approved</span></Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="LocationSummary" Property="NotApproved" Title="No Aprobadas" Width="115px">
                                    <Template Context="m"><span style="color:var(--rz-danger)">@m.NotApproved</span></Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenCard>
                </RadzenColumn>
            }
        </RadzenRow>
    }
}

@code {
    private bool _loading = true;
    private string? _errorMsg;
    private KpiSummary? _kpis;
    private List<GroupSummary> _groups = [];
    private List<SectionPoint> _sectionPoints = [];
    private List<SectionGroupPoint> _sectionGroupPoints = [];
    private List<StoreRow> _rows = [];
    private List<LocationSummary> _departamentos = [];
    private List<LocationSummary> _municipios = [];
    private List<int> _years = [];
    private int? _year;
    private int? _month;
    private List<int> _availableMonths = [];
    private List<MonthOption> _monthOptions = [];

    private static readonly string[] SectionCols =
        ["Fact. Riesgo", "Limpieza", "Mantenimiento", "Almacenaje", "Conocimiento"];

    private static readonly Dictionary<int, string> _monthNames = new()
    {
        {1,"Enero"},{2,"Febrero"},{3,"Marzo"},{4,"Abril"},{5,"Mayo"},{6,"Junio"},
        {7,"Julio"},{8,"Agosto"},{9,"Septiembre"},{10,"Octubre"},{11,"Noviembre"},{12,"Diciembre"}
    };

    private ApexChartOptions<GroupSummary> _groupChartOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        Yaxis = [new YAxis { Min = 50, Max = 100, Labels = new YAxisLabels { Formatter = "function(v){return v+'%'}" } }],
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 4 } },
        DataLabels = new DataLabels { Enabled = true, Formatter = "function(v){return v+'%'}" },
    };

    private ApexChartOptions<SectionPoint> _sectionChartOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        Yaxis = [new YAxis { Min = 50, Max = 100, Labels = new YAxisLabels { Formatter = "function(v){return v+'%'}" } }],
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 4 } },
        DataLabels = new DataLabels { Enabled = true, Formatter = "function(v){return v+'%'}" },
    };

    private ApexChartOptions<SectionGroupPoint> _sectionGroupOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        Yaxis = [new YAxis { Min = 50, Max = 100, Labels = new YAxisLabels { Formatter = "function(v){return v+'%'}" } }],
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 3 } },
        DataLabels = new DataLabels { Enabled = true, Formatter = "function(v){return v+'%'}" },
    };

    private ApexChartOptions<StoreRow> _storeRankOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = true, BorderRadius = 2 } },
        Xaxis = new XAxis { Min = 50, Max = 100 },
        DataLabels = new DataLabels { Enabled = true, Formatter = "function(v){return v+'%'}" },
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var yearsTask  = AuditSvc.GetAvailableYearsAsync();
            var monthsTask = AuditSvc.GetAvailableMonthsAsync(null);
            await Task.WhenAll(yearsTask, monthsTask);
            _years           = yearsTask.Result;
            _availableMonths = monthsTask.Result;
            _monthOptions    = BuildMonthOptions(_availableMonths);
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
            _loading  = false;
        }
    }

    private async Task OnYearChanged(object value)
    {
        _availableMonths = await AuditSvc.GetAvailableMonthsAsync(_year);
        if (_month.HasValue && !_availableMonths.Contains(_month.Value))
            _month = null;
        _monthOptions = BuildMonthOptions(_availableMonths);
    }

    private async Task LoadData()
    {
        _loading = true;
        _errorMsg = null;
        try
        {
            _kpis          = await AuditSvc.GetKpiSummaryAsync(_year, _month);
            _groups        = await AuditSvc.GetGroupSummariesAsync(_year, _month);
            _rows          = await AuditSvc.GetStoreRowsAsync(_year, _month);
            _departamentos = await AuditSvc.GetDepartamentoSummariesAsync(_year, _month);
            _municipios    = await AuditSvc.GetMunicipioSummariesAsync(_year, _month);
            _sectionPoints = _kpis.SectionAverages
                .Select(kv => new SectionPoint(kv.Key, kv.Value)).ToList();
            _sectionGroupPoints = _groups.SelectMany(g =>
                SectionCols.Select(sec =>
                    new SectionGroupPoint(sec, g.Group, g.SectionAverages.GetValueOrDefault(sec)))
            ).ToList();
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportExcel()
    {
        var bytes = await ExportSvc.ExportStoreDetailAsync(_year, _month);
        var b64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFileFromBase64", b64, "Reporte_FoodSafety.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private List<MonthOption> BuildMonthOptions(List<int> months) =>
        months.Select(m => new MonthOption(m, _monthNames[m])).ToList();

    private BadgeStyle ScoreBadgeStyle(double score) => score switch
    {
        >= 95 => BadgeStyle.Success,
        >= 85 => BadgeStyle.Warning,
        _     => BadgeStyle.Danger
    };

    private record MonthOption(int Value, string Text);
    private record SectionPoint(string Section, double Score);
    private record SectionGroupPoint(string Section, string Group, double Score);
}
