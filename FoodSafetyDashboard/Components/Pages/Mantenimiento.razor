@page "/mantenimiento"
@rendermode InteractiveServer
@inject PdfProcessingService PdfSvc
@inject IJSRuntime JS

<PageTitle>Carga de Auditorías</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Carga de Auditorías PDF</RadzenText>

<InputFile id="pdfInput" multiple accept=".pdf" OnChange="OnFilesSelected" style="display:none" />

<RadzenCard class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">1. Subir archivos PDF</RadzenText>
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px" Wrap="FlexWrap.Wrap">
        <RadzenButton Text="Seleccionar PDFs" ButtonStyle="ButtonStyle.Light"
                      Icon="upload_file" Click="OpenFilePicker" />
        @if (_selectedFiles.Count > 0)
        {
            <RadzenText TextStyle="TextStyle.Body2">@_selectedFiles.Count archivo(s) seleccionado(s)</RadzenText>
        }
        <RadzenButton Text="@(_uploading ? "Subiendo..." : "Subir PDFs")"
                      ButtonStyle="ButtonStyle.Primary" Icon="cloud_upload"
                      Click="UploadFiles"
                      Disabled="_selectedFiles.Count == 0 || _uploading"
                      Style="margin-left:auto" />
    </RadzenStack>
    @if (!string.IsNullOrEmpty(_uploadMessage))
    {
        <RadzenAlert AlertStyle="@_uploadAlertStyle" class="rz-mt-3" Shade="Shade.Lighter">
            @_uploadMessage
        </RadzenAlert>
    }
</RadzenCard>

<RadzenCard class="rz-mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-3">
        <RadzenText TextStyle="TextStyle.H6">
            2. Cola de procesamiento
            <RadzenBadge Text="@_pendingFiles.Count.ToString()"
                         BadgeStyle="@(_pendingFiles.Count > 0 ? BadgeStyle.Warning : BadgeStyle.Light)"
                         style="margin-left:8px" />
        </RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" Style="margin-left:auto">
            <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light"
                          Click="RefreshPending" title="Actualizar lista" />
            <RadzenButton Text="@(_running ? "Ejecutando..." : "Ejecutar Parser")"
                          ButtonStyle="ButtonStyle.Success" Icon="play_arrow"
                          Click="RunParser"
                          Disabled="_pendingFiles.Count == 0 || _running" />
        </RadzenStack>
    </RadzenStack>

    @if (_pendingFiles.Count > 0)
    {
        <RadzenDataGrid Data="@_pendingFiles" TItem="string"
                        Density="Density.Compact" Style="height:300px">
            <Columns>
                <RadzenDataGridColumn TItem="string" Title="#" Width="50px">
                    <Template Context="f">@(_pendingFiles.IndexOf(f) + 1)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="string" Title="Archivo">
                    <Template Context="f">
                        <RadzenIcon Icon="picture_as_pdf" style="color:var(--rz-danger);margin-right:6px;font-size:1rem" />
                        @f
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="string" Title="Estado" Width="120px">
                    <Template Context="f">
                        <RadzenBadge Text="Pendiente" BadgeStyle="BadgeStyle.Warning" Shade="Shade.Lighter" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
    else
    {
        <RadzenText Style="text-align:center;color:var(--rz-text-secondary-color);padding:1rem">
            No hay archivos PDF en la cola. Sube archivos para procesar.
        </RadzenText>
    }
</RadzenCard>

@if (!string.IsNullOrEmpty(_runOutput))
{
    <RadzenCard>
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">3. Resultado de ejecución</RadzenText>
        <RadzenAlert AlertStyle="@(_exitCode == 0 ? AlertStyle.Success : AlertStyle.Danger)"
                     Shade="Shade.Lighter" class="rz-mb-3">
            @(_exitCode == 0
                ? "Procesamiento completado. Los datos fueron insertados en la base de datos."
                : $"El parser terminó con error (código {_exitCode}). Revisa el log.")
        </RadzenAlert>
        <pre style="background:#1e1e1e;color:#d4d4d4;padding:16px;border-radius:4px;
                    overflow-x:auto;font-size:0.82rem;max-height:420px;overflow-y:auto;
                    white-space:pre-wrap;word-break:break-all">@_runOutput</pre>
    </RadzenCard>
}

@code {
    private List<IBrowserFile> _selectedFiles = [];
    private List<string> _pendingFiles = [];
    private bool _uploading;
    private bool _running;
    private string _uploadMessage = string.Empty;
    private AlertStyle _uploadAlertStyle = AlertStyle.Info;
    private string _runOutput = string.Empty;
    private int _exitCode;

    protected override void OnInitialized() => RefreshPending();

    private async Task OpenFilePicker()
    {
        await JS.InvokeVoidAsync("clickById", "pdfInput");
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        _selectedFiles = [.. e.GetMultipleFiles(200)];
        _uploadMessage = string.Empty;
    }

    private async Task UploadFiles()
    {
        _uploading = true;
        _uploadMessage = string.Empty;
        StateHasChanged();

        var ok = 0;
        var failed = 0;
        var failNames = new List<string>();

        foreach (var file in _selectedFiles)
        {
            try { await PdfSvc.SaveFileAsync(file); ok++; }
            catch { failed++; failNames.Add(file.Name); }
        }

        _selectedFiles = [];
        RefreshPending();

        _uploadAlertStyle = failed == 0 ? AlertStyle.Success : AlertStyle.Warning;
        _uploadMessage = failed == 0
            ? $"{ok} archivo(s) subido(s) correctamente."
            : $"Subidos: {ok}  |  Errores: {failed} ({string.Join(", ", failNames)})";

        _uploading = false;
    }

    private async Task RunParser()
    {
        _running = true;
        _runOutput = string.Empty;
        StateHasChanged();

        var (output, exitCode) = await PdfSvc.RunParserAsync();
        _runOutput = output;
        _exitCode = exitCode;

        RefreshPending();
        _running = false;
    }

    private void RefreshPending()
    {
        _pendingFiles = [.. PdfSvc.GetPendingFiles()];
        StateHasChanged();
    }
}
