@page "/hallazgos"
@rendermode InteractiveServer
@inject AuditService AuditSvc

<PageTitle>Hallazgos Sistémicos</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Hallazgos Sistémicos</RadzenText>

@if (_loading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" class="rz-mb-4" />
}
else
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeSM="4">
            <RadzenCard style="border-left:4px solid #C00000;text-align:center;padding:1rem">
                <RadzenText TextStyle="TextStyle.H4" style="color:#C00000;font-weight:700">
                    @_findings.Count(f => f.Severity == "CRÍTICO")
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body1">Hallazgos CRÍTICOS</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeSM="4">
            <RadzenCard style="border-left:4px solid #ED7D31;text-align:center;padding:1rem">
                <RadzenText TextStyle="TextStyle.H4" style="color:#ED7D31;font-weight:700">
                    @_findings.Count(f => f.Severity == "ALTO")
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body1">Hallazgos ALTO</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeSM="4">
            <RadzenCard style="border-left:4px solid #FFD966;text-align:center;padding:1rem">
                <RadzenText TextStyle="TextStyle.H4" style="color:#b8860b;font-weight:700">
                    @_findings.Count(f => f.Severity == "MODERADO")
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body1">Hallazgos MODERADOS</RadzenText>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <RadzenDataGrid Data="@_findings" TItem="SystemicFinding"
                        AllowSorting="true" AllowGrouping="true"
                        Density="Density.Compact">
            <Columns>
                <RadzenDataGridColumn TItem="SystemicFinding" Property="Severity" Title="Severidad" Width="120px" Groupable="true">
                    <Template Context="f">
                        <RadzenBadge Text="@f.Severity" BadgeStyle="@SevBadgeStyle(f.Severity)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SystemicFinding" Property="Description" Title="Descripción" />
                <RadzenDataGridColumn TItem="SystemicFinding" Property="Category" Title="Categoría" Width="130px" />
                <RadzenDataGridColumn TItem="SystemicFinding" Property="StoreCount" Title="Tiendas Afectadas" Width="100px">
                    <Template Context="f">
                        @foreach (var sid in f.AffectedStores.Take(6))
                        {
                            <RadzenBadge Text="@sid.ToString()" BadgeStyle="BadgeStyle.Light" class="rz-mr-1" />
                        }
                        @if (f.AffectedStores.Count > 6)
                        {
                            <RadzenBadge Text="@($"+{f.AffectedStores.Count - 6}")" BadgeStyle="BadgeStyle.Dark" />
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SystemicFinding" Property="Action" Title="Acción Requerida" />
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
}

@code {
    private bool _loading = true;
    private List<SystemicFinding> _findings = [];

    protected override async Task OnInitializedAsync()
    {
        _findings = await AuditSvc.GetSystemicFindingsAsync();
        _loading = false;
    }

    private BadgeStyle SevBadgeStyle(string severity) => severity switch
    {
        "CRÍTICO"  => BadgeStyle.Danger,
        "ALTO"     => BadgeStyle.Warning,
        _          => BadgeStyle.Light
    };
}
