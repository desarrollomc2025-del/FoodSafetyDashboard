@page "/tiendas"
@rendermode InteractiveServer
@inject AuditService AuditSvc
@inject ExportService ExportSvc
@inject IJSRuntime JS

<PageTitle>Detalle por Tienda</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Detalle por Tienda</RadzenText>

<RadzenCard class="rz-mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="12px" Wrap="FlexWrap.Wrap">
        <RadzenDropDown @bind-Value="_year" Data="@_years"
                        AllowClear="true" Placeholder="Año" Style="width:130px" />
        <RadzenDropDown @bind-Value="_groupFilter" Data="@_groupOptions"
                        AllowClear="true" Placeholder="Grupo" Style="width:130px" />
        <RadzenDropDown @bind-Value="_resultFilter" Data="@_resultOptions"
                        AllowClear="true" Placeholder="Resultado" Style="width:150px" />
        <RadzenButton Text="Aplicar" ButtonStyle="ButtonStyle.Primary" Click="LoadData" />
        <RadzenButton Text="Excel" ButtonStyle="ButtonStyle.Success" Icon="download" Click="ExportExcel" />
    </RadzenStack>
</RadzenCard>

@if (_errorMsg is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" class="rz-mb-4">@_errorMsg</RadzenAlert>
}

@if (_loading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenCard>
        <RadzenDataGrid Data="@FilteredRows" TItem="StoreRow"
                        AllowSorting="true" AllowColumnResize="true"
                        Density="Density.Compact" Style="height:600px">
            <Columns>
                <RadzenDataGridColumn TItem="StoreRow" Property="StoreId" Title="Tienda" Width="80px" Frozen="true">
                    <Template Context="r"><b>@r.StoreId</b></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Property="Group" Title="Grupo" Width="90px">
                    <Template Context="r">
                        <RadzenBadge Text="@r.Group"
                                     BadgeStyle="@(r.Group == "DEX" ? BadgeStyle.Info : BadgeStyle.Light)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Property="AuditDate" Title="Fecha" Width="110px">
                    <Template Context="r">@r.AuditDate?.ToString("yyyy-MM-dd")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Property="Score" Title="Nota %" Width="100px">
                    <Template Context="r">
                        <RadzenBadge Text="@($"{r.Score:F1}%")"
                                     BadgeStyle="@ScoreBadgeStyle(r.Score)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Property="Result" Title="Resultado" Width="110px">
                    <Template Context="r">
                        <RadzenBadge Text="@r.Result"
                                     BadgeStyle="@(r.Result == "Aprobado" ? BadgeStyle.Success : BadgeStyle.Danger)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Property="CriticalViolations" Title="Críticos" Width="80px">
                    <Template Context="r">
                        @if (r.CriticalViolations > 0)
                        {
                            <RadzenBadge Text="@r.CriticalViolations.ToString()" BadgeStyle="BadgeStyle.Danger" />
                        }
                        else
                        {
                            <span>0</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Title="Fact. Riesgo" Width="105px">
                    <Template Context="r">@FormatSection(r.Sections.GetValueOrDefault("Fact. Riesgo"))</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Title="Limpieza" Width="95px">
                    <Template Context="r">@FormatSection(r.Sections.GetValueOrDefault("Limpieza"))</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Title="Mantenimiento" Width="115px">
                    <Template Context="r">@FormatSection(r.Sections.GetValueOrDefault("Mantenimiento"))</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Title="Almacenaje" Width="105px">
                    <Template Context="r">@FormatSection(r.Sections.GetValueOrDefault("Almacenaje"))</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Title="Conocimiento" Width="110px">
                    <Template Context="r">@FormatSection(r.Sections.GetValueOrDefault("Conocimiento"))</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="StoreRow" Property="TotalViolations" Title="Fallos" Width="75px" />
                <RadzenDataGridColumn TItem="StoreRow" Property="Points" Title="Puntos" Width="85px" />
            </Columns>
        </RadzenDataGrid>
        @if (FilteredRows.Any())
        {
            <RadzenStack Orientation="Orientation.Horizontal" class="rz-mt-2 rz-p-2">
                <RadzenText TextStyle="TextStyle.Body2">
                    <b>Promedio: @FilteredRows.Average(r => r.Score).ToString("F1")%</b>
                    &nbsp;|&nbsp; @FilteredRows.Count() tiendas
                </RadzenText>
            </RadzenStack>
        }
    </RadzenCard>
}

@code {
    private bool _loading = true;
    private string? _errorMsg;
    private List<StoreRow> _rows = [];
    private List<int> _years = [];
    private int? _year;
    private string? _groupFilter;
    private string? _resultFilter;

    private static readonly string[] _groupOptions  = ["CLÁSICA", "DEX"];
    private static readonly string[] _resultOptions = ["Aprobado", "No aprobado"];

    private IEnumerable<StoreRow> FilteredRows => _rows
        .Where(r => _groupFilter  == null || r.Group  == _groupFilter)
        .Where(r => _resultFilter == null || r.Result == _resultFilter);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _years = await AuditSvc.GetAvailableYearsAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
            _loading = false;
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        _errorMsg = null;
        try
        {
            _rows = await AuditSvc.GetStoreRowsAsync(_year);
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportExcel()
    {
        var bytes = await ExportSvc.ExportStoreDetailAsync(_year);
        var b64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFileFromBase64", b64, "Reporte_Tiendas.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private static string FormatSection(double? val) => val.HasValue ? $"{val.Value:F1}%" : "—";

    private BadgeStyle ScoreBadgeStyle(double score) => score switch
    {
        >= 95 => BadgeStyle.Success,
        >= 85 => BadgeStyle.Warning,
        _     => BadgeStyle.Danger
    };
}
