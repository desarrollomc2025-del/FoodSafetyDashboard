@page "/plan-accion"
@rendermode InteractiveServer
@inject AuditService AuditSvc

<PageTitle>Plan de Acción</PageTitle>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Plan de Acción Correctivo</RadzenText>

@if (_loading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="6" SizeSM="3">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenText TextStyle="TextStyle.H4" style="font-weight:700">@_items.Count</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">Total Acciones</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeSM="3">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-danger);font-weight:700">
                    @_items.Count(i => i.Priority is "INMEDIATO" or "CRÍTICO")
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">Inmediatas / Críticas</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeSM="3">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-warning);font-weight:700">
                    @_items.Count(i => i.Priority == "ALTO")
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">Prioridad Alta</RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeSM="3">
            <RadzenCard style="text-align:center;padding:1rem">
                <RadzenText TextStyle="TextStyle.H4" style="color:var(--rz-success);font-weight:700">
                    @_items.Count(i => i.Status == "Completado")
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">Completadas</RadzenText>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <RadzenDataGrid Data="@_items" TItem="ActionItem"
                        AllowSorting="true" Density="Density.Compact"
                        Style="height:600px">
            <Columns>
                <RadzenDataGridColumn TItem="ActionItem" Property="Index" Title="#" Width="50px" />
                <RadzenDataGridColumn TItem="ActionItem" Property="Action" Title="Acción" MinWidth="220px" />
                <RadzenDataGridColumn TItem="ActionItem" Property="Stores" Title="Tiendas" Width="120px" />
                <RadzenDataGridColumn TItem="ActionItem" Property="Priority" Title="Prioridad" Width="110px">
                    <Template Context="item">
                        <RadzenBadge Text="@item.Priority" BadgeStyle="@PriorityBadgeStyle(item.Priority)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActionItem" Property="Deadline" Title="Plazo" Width="110px" />
                <RadzenDataGridColumn TItem="ActionItem" Property="Responsible" Title="Responsable" Width="150px" />
                <RadzenDataGridColumn TItem="ActionItem" Property="Status" Title="Estado" Width="160px">
                    <Template Context="item">
                        <RadzenDropDown TValue="string" Value="@item.Status"
                                        Data="@_statusOptions"
                                        Change="@(v => UpdateStatus(item, v?.ToString() ?? string.Empty))"
                                        Style="width:100%;font-size:0.82rem" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActionItem" Property="Notes" Title="Observaciones" MinWidth="200px">
                    <Template Context="item">
                        <span style="font-size:0.78rem">@item.Notes</span>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
}

@code {
    private bool _loading = true;
    private List<ActionItem> _items = [];

    private static readonly string[] _statusOptions =
        ["Pendiente", "En curso", "Acción iniciada", "Completado"];

    protected override async Task OnInitializedAsync()
    {
        _items = await AuditSvc.GetActionPlanAsync();
        _loading = false;
    }

    private void UpdateStatus(ActionItem item, string newStatus)
    {
        var idx = _items.IndexOf(item);
        if (idx >= 0)
            _items[idx] = item with { Status = newStatus };
    }

    private BadgeStyle PriorityBadgeStyle(string priority) => priority switch
    {
        "INMEDIATO" => BadgeStyle.Danger,
        "CRÍTICO"   => BadgeStyle.Danger,
        "ALTO"      => BadgeStyle.Warning,
        _           => BadgeStyle.Light
    };
}
